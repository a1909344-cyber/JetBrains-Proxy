# ── Required ─────────────────────────────────────────────────────────────────

# Admin panel login password (set something strong!)
ADMIN_PASSWORD=change-me-strong-password

# Secret used to sign admin tokens (random string, at least 32 chars)
SESSION_SECRET=change-me-random-secret-at-least-32-chars

# ── Optional ──────────────────────────────────────────────────────────────────

# Port to expose the web interface on the host (default: 80)
# HTTP_PORT=80
